# App
PORT=3000
NODE_ENV=development

# Postgres (Neon serverless)
# Pooled connection (PgBouncer) — used by the running app at runtime.
DATABASE_URL="postgresql://<user>:<password>@<pooler-host>/<database>?sslmode=require"
# Direct connection (no pooler) — used only by TypeORM migration CLI commands.
DIRECT_URL="postgresql://<user>:<password>@<direct-host>/<database>?sslmode=require"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"
