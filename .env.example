# App
PORT=8080
NODE_ENV=development

# Postgres (Neon serverless)
# Pooled connection (PgBouncer) — used by the running app at runtime.
DATABASE_URL="postgresql://<user>:<password>@<pooler-host>/<database>?sslmode=require"
# Direct connection (no pooler) — used only by TypeORM migration CLI commands.
DIRECT_URL="postgresql://<user>:<password>@<direct-host>/<database>?sslmode=require"
# true for Neon (TLS mandatory there) — set to false when running against the local
# Postgres container from docker-compose.yml, which doesn't support TLS.
DB_SSL=true

# Auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="15m"
# Must be a different secret from JWT_SECRET. REFRESH_TOKEN_EXPIRES_IN is currently
# equal to JWT_EXPIRES_IN (fine for local dev/demo) — in production, prefer making
# it longer than JWT_EXPIRES_IN so there's a safety buffer for a client to refresh
# reactively (after the access token has already expired) without a timing race
# against the refresh token also expiring at the same instant.
REFRESH_TOKEN_SECRET="replace-with-a-different-long-random-secret"
REFRESH_TOKEN_EXPIRES_IN="15m"
